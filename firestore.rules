rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated()
        && request.auth.token.email == 'venkatavishnu.skksv@gmail.com'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isAdmin() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'admin'];
    }

    function isStaff() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    function isStudent() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userHasStatus(status) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == status;
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      // Admins can read any profile
      allow read: if isAuthenticated()
        && (isAdmin() || isOwner(userId)
        || (isStaff() && resource.data.role in ['student', 'staff'])
        || (isStudent() && isOwner(userId)));

      // Admins can create any user
      // Staff can create student users
      allow create: if isAdmin()
        || (isStaff() && request.resource.data.role == 'student');
      // Admins can update any user
      // Staff can update student users
      // Users can update their own limited fields
      allow update: if isAdmin()
        || (isStaff() && resource.data.role == 'student')
        || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'phone', 'profileImage', 'customFields']));
      allow delete: if isSuperAdmin();
    }

    // Roles collection
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Permissions collection
    match /permissions/{permissionId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Role-Permissions collection
    match /rolePermissions/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Audit logs collection
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuthenticated()
        && (isAdmin() || isStaff() || isOwner(studentId));
      allow write: if isAdmin() || isStaff();
    }

    // Staff collection
    match /staff/{staffId} {
      allow read: if isAuthenticated()
        && (isAdmin() || isOwner(staffId));
      allow write: if isAdmin();
    }

    // Schools collection (future multi-school support)
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Images collection (carousel, gallery, etc.)
    match /images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SKKSV images collection
    match /skksv-images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Exam types collection
    match /examTypes/{typeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStaff();
    }

    // Exam configs collection (assessment content)
    match /examConfigs/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStaff();
    }

    // Exam index collection (class/subject mappings)
    match /examIndex/{indexId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStaff();
    }

    // Submissions collection (coding, projects, etc.)
    match /submissions/{submissionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Existing collections (keep access patterns)
    match /quizResults/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

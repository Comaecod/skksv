# Firebase Configuration
# Copy this file to .env and fill in your values
# Get these from: Firebase Console > Project Settings > Your Apps > Web App

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Application URL (required for email link/passwordless auth)
# Must match the authorized domain configured in Firebase Console
# IMPORTANT: Update this to your actual domain (e.g., https://yourdomain.com)
VITE_APP_URL=http://localhost:3000

# Super Admin Configuration
# This is a special account with unrestricted access to the entire application
# The email will be used as the Super Admin identifier
VITE_SUPER_ADMIN_EMAIL=superadmin@school.com

# Admin Key (used across all admin-protected pages)
VITE_ADMIN_KEY=your_admin_key_here

# Cloudinary Configuration
# Get these from: Cloudinary Dashboard > Account Details
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_API_SECRET=your_api_secret

# Groq API Key (for Sankara AI assistant - uses open-source Llama models)
# Get a free API key from: https://console.groq.com
# Without this, Sankara will use a local knowledge base with basic responses
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google Auth
# Client ID for Google Sign-In (from Google Cloud Console)
# Required for Google authentication
# VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Firebase Web API Key (also used for Firebase Auth REST API)
# Already configured as VITE_FIREBASE_API_KEY above
